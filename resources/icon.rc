// Resource file for ComChemKit icon
// This file defines the application icon for Windows executables

#include <windows.h>

// Application icon
IDI_APP_ICON ICON "app_icon.ico"

// Optional: Version information
VS_VERSION_INFO VERSIONINFO
 FILEVERSION 0,0,0,7
 PRODUCTVERSION 0,0,0,7
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "ComChemKit Project"
            VALUE "FileDescription", "Multi-function toolkit for computational chemistry: input creation, data extraction, thermodynamics calculation, and job management"
            VALUE "FileVersion", "0.0.0.7"
            VALUE "InternalName", "cck"
            VALUE "LegalCopyright", "Copyright (C) 2026"
            VALUE "OriginalFilename", "cck.exe"
            VALUE "ProductName", "ComChemKit"
            VALUE "ProductVersion", "0.0.0.7"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END